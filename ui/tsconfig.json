{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/storybook",
    "src/api/environments.ts",
    "src/api/execution-workspaces.ts",
    "src/api/plugins.ts",
    "src/api/search.ts",
    "src/components/ActivityCharts.tsx",
    "src/components/IssueBlockedNotice.tsx",
    "src/components/IssueContinuationHandoff.tsx",
    "src/components/IssueMonitorActivityCard.tsx",
    "src/components/IssueRunLedger.tsx",
    "src/components/IssueScheduledRetryCard.tsx",
    "src/components/IssueThreadInteractionCard.tsx",
    "src/components/KanbanBoard.tsx",
    "src/components/LiveRunWidget.tsx",
    "src/components/ProductivityReviewBadge.tsx",
    "src/components/ProjectWorkspacesContent.tsx",
    "src/components/RoutineHistoryTab.tsx",
    "src/components/RoutineList.tsx",
    "src/components/agent-config-defaults.ts",
    "src/components/search",
    "src/pages/UserProfile.tsx",
    "src/pages/Workspaces.tsx",
    "src/plugins/bridge-init.ts",
    "src/plugins/slots.tsx",
    "src/plugins/bridge.ts",
    "src/plugins/launchers.tsx",
    "src/plugins/bridge.test.ts",
    "src/adapters/local-workspace-runtime-fields.tsx",
    "src/lib/project-workspaces-tab.ts",
    "src/lib/company-members.ts",
    "src/lib/reusable-execution-workspaces.ts",
    "src/lib/reusable-execution-workspaces.test.ts",
    "src/lib/workspace-routines.ts",
    "src/lib/workspace-routines.test.ts",
    "src/lib/worktree-branding.ts",
    "src/lib/recent-searches.ts"
  ]
}
