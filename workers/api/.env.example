# Local development environment variables for workers/api
# Copy this file to .dev.vars (used by wrangler dev) and fill in real values.
# NEVER commit .dev.vars to git.

# ─── Deployment ──────────────────────────────────────────────────────────────
# "local_trusted" = no login required (default for local dev)
# "authenticated" = login required (use for staging/production)
DEPLOYMENT_MODE=local_trusted

# Disable new user signups (set to "true" for closed deployments)
AUTH_DISABLE_SIGNUP=true

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Required when DEPLOYMENT_MODE=authenticated.
# Generate a secure secret:  openssl rand -hex 32
# Set in production via:     wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=replace-with-output-of-openssl-rand-hex-32

# ─── R2 Storage ──────────────────────────────────────────────────────────────
# Credentials for the R2 bucket used for asset storage.
# Set in production via: wrangler secret put R2_ACCESS_KEY_ID
#                        wrangler secret put R2_SECRET_ACCESS_KEY
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
